# Geocoding — api-adresse.data.gouv.fr
GEOCODING_API_URL=https://api-adresse.data.gouv.fr/search/
GEOCODING_TIMEOUT_SECONDS=10.0
# Reject geocoding results below this confidence score (0.0–1.0)
GEOCODING_SCORE_THRESHOLD=0.4

# Request limits
# HTTP 422 is returned when this limit is exceeded
MAX_ADDRESSES_PER_REQUEST=50

# CORS — space-separated list of allowed origins
# Set to the Vite dev server in development; not needed in production
# when the Vue build is served as static files from FastAPI itself
CORS_ORIGINS=["http://localhost:5173"]

# Logging — "console" for human-readable dev output, "json" for production
LOG_FORMAT=console

# Data — path to the processed antenna parquet file
# Run `make preprocess` to generate it
DATA_PATH=data/processed/antennas.parquet

# ---------------------------------------------------------------------------
# Production deployment — APP_ENV GitHub secret
# ---------------------------------------------------------------------------
# In CI/CD the entire .env is stored as a single GitHub secret called APP_ENV.
# The deploy workflow writes it to disk with:
#   printf '%s' "$APP_ENV" > .env
#
# Use printf (not echo) so JSON values such as CORS_ORIGINS are not corrupted
# by shell quote expansion.
#
# Recommended production values:
#   LOG_FORMAT=json
#   CORS_ORIGINS=["https://your-domain.com"]
#   GEOCODING_TIMEOUT_SECONDS=10.0
#   MAX_ADDRESSES_PER_REQUEST=50
#   DATA_PATH=data/processed/antennas.parquet
